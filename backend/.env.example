# Database (로컬 개발용 — 프로덕션은 RDS 엔드포인트로 교체)
DATABASE_URL=postgresql+asyncpg://farm:farm_secret@db:5432/farm_db

# JWT (프로덕션에서는 반드시 강력한 랜덤값으로 교체)
SECRET_KEY=super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (프로덕션에서는 실제 도메인으로 교체)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Admin seed
ADMIN_EMAIL=admin@farm.example.com
ADMIN_PASSWORD=admin1234
ADMIN_NAME=농장관리자

# SMS (알리고)
ALIGO_API_KEY=
ALIGO_USER_ID=
ALIGO_SENDER=
ADMIN_PHONE=

# 무통장 입금 계좌 정보
BANK_ACCOUNT=농협 716-12-338141
BANK_HOLDER=

# 주문 설정
PAYMENT_DEADLINE_HOURS=48
JEJU_ADDITIONAL_FEE=3000
REMOTE_AREA_ADDITIONAL_FEE=5000

# Google OAuth (관리자 로그인)
GOOGLE_CLIENT_ID=

# AWS S3 이미지 스토리지 (USE_S3=true 시 활성화)
USE_S3=false
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=
S3_CDN_BASE_URL=
# EC2 IAM Role 사용 시 아래 두 항목 불필요 (비워두면 됨)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
